import tkinter as tk
import random
import json
import os

# Список цитат (текст, автор, тема)
quotes = [
    {"text": "Жизнь - это то, что происходит, пока вы заняты строить другие планы.", "author": "Джон Леннон", "topic": "жизнь"},
    {"text": "Мы не видим вещей такими, какие они есть, мы видим вещи такими, какие мы есть.", "author": "Тулси", "topic": "психология"},
    {"text": "Сложности - это те вещи, которые появляются, когда вы отвлекаетесь от целей.", "author": "Роберт Хайнлайн", "topic": "мотивация"},
    {"text": "Смех - это солнечный свет, который проникает в человеческую душу.", "author": "Христиан Наркевич", "topic": "радость"},
]

# Имя файла для сохранения истории
history_file = 'quote_history.json'
history = []

# Загружает историю из JSON
def load_history():
    if os.path.exists(history_file):
        with open(history_file, 'r') as file:
            return json.load(file)
    return []

# Сохраняет историю в JSON
def save_history():
    with open(history_file, 'w') as file:
        json.dump(history, file)

# Генерация случайной цитаты
def generate_quote():
    quote = random.choice(quotes)
    history.append(quote)
    save_history()
    update_display()

# Обновляет текстовое поле с выводом
def update_display():
    if history:
        last_quote = history[-1]
        quote_text.set(f'"{last_quote["text"]}" - {last_quote["author"]} ({last_quote["topic"]})')
        history_list_var.set('\n'.join([f'"{q["text"]}" - {q["author"]} ({q["topic"]})' for q in history]))

# Фильтрация цитат по автору или теме
def filter_quotes():
    author_filter = author_entry.get().lower()
    topic_filter = topic_entry.get().lower()

    filtered_quotes = [
        f'"{q["text"]}" - {q["author"]} ({q["topic"]})'
        for q in history
        if (author_filter in q["author"].lower() and topic_filter in q["topic"].lower())
    ]
    history_list_var.set('\n'.join(filtered_quotes))

# Инициализация GUI
root = tk.Tk()
root.title("Random Quote Generator")

quote_text = tk.StringVar()
history_list_var = tk.StringVar()
history = load_history()

tk.Label(root, textvariable=quote_text, wraplength=400).pack(pady=10)
tk.Button(root, text="Сгенерировать цитату", command=generate_quote).pack(pady=10)

tk.Label(root, text="Фильтр по автору:").pack(pady=5)
author_entry = tk.Entry(root)
author_entry.pack(pady=5)

tk.Label(root, text="Фильтр по теме:").pack(pady=5)
topic_entry = tk.Entry(root)
topic_entry.pack(pady=5)

tk.Button(root, text="Фильтровать", command=filter_quotes).pack(pady=10)
tk.Label(root, text="История цитат:").pack(pady=5)
history_list = tk.Label(root, textvariable=history_list_var, justify='left')
history_list.pack(pady=10)

# Заполняем вывод историей при загрузке
update_display()

root.mainloop()
