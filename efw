import tkinter as tk
from tkinter import ttk, messagebox
import requests
import json
from datetime import datetime

class CurrencyConverter:
    def __init__(self, root, api_key):
        self.root = root
        self.root.title("Currency Converter")
        self.root.geometry("700x550")
        self.api_key = api_key
        self.history = []
        self.currencies = []

        self.load_history()
        self.fetch_currencies()
        self.create_widgets()

    def fetch_currencies(self):
        """Загрузка списка валют из API"""
        try:
            url = "https://api.exchangerate-api.com/v4/latest/USD"
            response = requests.get(url)
            data = response.json()
            self.currencies = sorted(data['rates'].keys())
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось загрузить список валют: {e}")
            # Резервный список валют
            self.currencies = ['USD', 'EUR', 'GBP', 'JPY', 'RUB', 'CNY', 'CAD']

    def create_widgets(self):
        # Основной фрейм
        main_frame = ttk.Frame(self.root, padding="10")
        main_frame.grid(row=0, column=0, sticky=(tk.W, tk.E, tk.N, tk.S))

        # Выбор валюты «из»
        ttk.Label(main_frame, text="Из валюты:").grid(row=0, column=0, padx=5, pady=5, sticky="w")
        self.from_combo = ttk.Combobox(main_frame, values=self.currencies, width=10)
        self.from_combo.set('USD')
        self.from_combo.grid(row=0, column=1, padx=5, pady=5)

        # Выбор валюты «в»
        ttk.Label(main_frame, text="В валюту:").grid(row=1, column=0, padx=5, pady=5, sticky="w")
        self.to_combo = ttk.Combobox(main_frame, values=self.currencies, width=10)
        self.to_combo.set('EUR')
        self.to_combo.grid(row=1, column=1, padx=5, pady=5)

        # Поле ввода суммы
        ttk.Label(main_frame, text="Сумма:").grid(row=2, column=0, padx=5, pady=5, sticky="w")
        self.amount_entry = ttk.Entry(main_frame, width=15)
        self.amount_entry.grid(row=2, column=1, padx=5, pady=5)

        # Кнопка конвертации
        ttk.Button(main_frame, text="Конвертировать",
                   command=self.convert_currency).grid(row=3, column=0, columnspan=2, pady=10)

        # Результат
        ttk.Label(main_frame, text="Результат:").grid(row=4, column=0, padx=5, pady=5, sticky="w")
        self.result_var = tk.StringVar()
        self.result_label = ttk.Label(main_frame, textvariable=self.result_var,
                                   font=("Arial", 12, "bold"))
        self.result_label.grid(row=4, column=1, padx=5, pady=5)

        # Таблица истории
        ttk.Label(main_frame, text="История конвертаций:").grid(row=5, column=0,
                   columnspan=2, padx=5, pady=5, sticky="w")

        columns = ("From", "To", "Amount", "Result", "Date")
        self.history_tree = ttk.Treeview(main_frame, columns=columns, show="headings", height=8)

        for col in columns:
            self.history_tree.heading(col, text=col)
            self.history_tree.column(col, width=120)

        self.history_tree.grid(row=6, column=0, columnspan=2, padx=5, pady=5,
                          sticky=(tk.W, tk.E, tk.N, tk.S))

        # Полоса прокрутки для таблицы
        scrollbar = ttk.Scrollbar(main_frame, orient="vertical",
                           command=self.history_tree.yview)
        scrollbar.grid(row=6, column=2, sticky=(tk.N, tk.S))
        self.history_tree.configure(yscrollcommand=scrollbar.set)

        # Кнопки сохранения/загрузки
        button_frame = ttk.Frame(main_frame)
        button_frame.grid(row=7, column=0, columnspan=2, pady=10)

        ttk.Button(button_frame, text="Сохранить историю",
                   command=self.save_history).pack(side=tk.LEFT, padx=5)
        ttk.Button(button_frame, text="Загрузить историю",
                   command=self.load_history).pack(side=tk.LEFT, padx=5)

        self.update_history_table()

    def validate_input(self):
        """Валидация ввода суммы"""
        try:
            amount = float(self.amount_entry.get())
            if amount <= 0:
                messagebox.showerror("Ошибка ввода", "Сумма должна быть положительным числом")
                return False
            return True
        except ValueError:
            messagebox.showerror("Ошибка ввода", "Введите корректное число")
            return False

    def convert_currency(self):
        """Конвертация валюты"""
        if not self.validate_input():
            return

        from_currency = self.from_combo.get()
        to_currency = self.to_combo.get()

        if from_currency == '' or to_currency == '':
            messagebox.showerror("Ошибка", "Выберите валюты для конвертации")
            return

        amount = float(self.amount_entry.get())

        try:
            url = f"https://api.exchangerate-api.com/v4/latest/{from_currency}"
            response = requests.get(url)
            response.raise_for_status()  # Проверка HTTP-статуса
            data = response.json()

            if to_currency in data['rates']:
                rate = data['rates'][to_currency]
                result = amount * rate
                self.result_var.set(f"{result:.2f} {to_currency}")

                # Добавляем в историю
                entry = {
                    "from": from_currency,
                    "to": to_currency,
            "amount": amount,
            "result": result,
            "date": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                }
                self.history.append(entry)
                self.update_history_table()
            else:
                messagebox.showerror("Ошибка", "Не удалось найти курс для выбранной валюты")
        except requests.exceptions.RequestException as e:
            messagebox.showerror("Ошибка сети", f"Ошибка при получении данных: {e}")
        except KeyError:
            messagebox.showerror("Ошибка данных", "Некорректный ответ от API")

    def update_history_table(self):
        """Обновление таблицы истории"""
        for item in self.history_tree.get_children():
            self.history_tree.delete(item)
        for entry in reversed(self.history[-10:]):  # Последние 10 записей
            self.history_tree.insert("", "end", values=(
                entry["from"],
                entry["to"],
                f"{entry['amount']:.2f}",
                f"{entry['result']:.2f}",
                entry["date"]
            ))

    def save_history(self):
        """Сохранение истории в JSON"""
        with open("currency_history.json", "w", encoding="utf-8") as f:
            json.dump(self.history, f, indent=4, ensure_ascii=False)
        messagebox.showinfo("Успех", "История сохранена в currency_history.json")

