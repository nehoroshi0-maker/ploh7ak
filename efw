import tkinter as tk
from tkinter import ttk, messagebox, filedialog
import json
from datetime import datetime

class WeatherDiary:
    def __init__(self, root):
        self.root = root
        self.root.title("Weather Diary")
        self.data = []

        self.create_widgets()
        self.load_data()

    def create_widgets(self):
        # Поля для ввода
        input_frame = ttk.Frame(self.root)
        input_frame.pack(padx=10, pady=10, fill='x')

        # Дата
        ttk.Label(input_frame, text="Дата (YYYY-MM-DD):").grid(row=0, column=0, sticky='w')
        self.date_entry = ttk.Entry(input_frame)
        self.date_entry.grid(row=0, column=1, sticky='w')

        # Температура
        ttk.Label(input_frame, text="Температура (°C):").grid(row=0, column=2, sticky='w', padx=(10,0))
        self.temp_entry = ttk.Entry(input_frame)
        self.temp_entry.grid(row=0, column=3, sticky='w')

        # Описание погоды
        ttk.Label(input_frame, text="Описание:").grid(row=1, column=0, sticky='w', pady=(10,0))
        self.desc_entry = ttk.Entry(input_frame, width=40)
        self.desc_entry.grid(row=1, column=1, columnspan=3, sticky='w', pady=(10,0))

        # Осадки
        self.precip_var = tk.BooleanVar()
        ttk.Checkbutton(input_frame, text="Осадки", variable=self.precip_var).grid(row=2, column=0, sticky='w', pady=(10,0))

        # Buttons
        btn_frame = ttk.Frame(self.root)
        btn_frame.pack(padx=10, pady=5, fill='x')

        ttk.Button(btn_frame, text="Добавить запись", command=self.add_record).pack(side='left', padx=5)
        ttk.Button(btn_frame, text="Сохранить", command=self.save_data).pack(side='left', padx=5)
        ttk.Button(btn_frame, text="Загрузить", command=self.load_data).pack(side='left', padx=5)
        ttk.Button(btn_frame, text="Все записи", command=self.show_all).pack(side='left', padx=5)

        # Фильтрация
        filter_frame = ttk.Frame(self.root)
        filter_frame.pack(padx=10, pady=10, fill='x')

        # Фильтр по дате
        ttk.Label(filter_frame, text="Фильтр по дате (YYYY-MM-DD):").grid(row=0, column=0, sticky='w')
        self.filter_date_entry = ttk.Entry(filter_frame)
        self.filter_date_entry.grid(row=0, column=1, sticky='w', padx=5)
        ttk.Button(filter_frame, text="Фильтр по дате", command=self.filter_by_date).grid(row=0, column=2, padx=5)

        # Фильтр по температуре
        ttk.Label(filter_frame, text="Показать выше температуры (°C):").grid(row=1, column=0, sticky='w')
        self.filter_temp_entry = ttk.Entry(filter_frame)
        self.filter_temp_entry.grid(row=1, column=1, sticky='w', padx=5)
        ttk.Button(filter_frame, text="Фильтр по температуре", command=self.filter_by_temperature).grid(row=1, column=2, padx=5)

        # Таблица для отображения данных
        self.tree = ttk.Treeview(self, columns=("date", "temp", "desc", "precip"), show='headings')
        self.tree.heading("date", text="Дата")
        self.tree.heading("temp", text="Температура")
        self.tree.heading("desc", text="Описание")
        self.tree.heading("precip", text="Осадки")
        self.tree.pack(padx=10, pady=10, fill='both', expand=True)

    def add_record(self):
        date_str = self.date_entry.get().strip()
        temp_str = self.temp_entry.get().strip()
        desc = self.desc_entry.get().strip()
        precip = self.precip_var.get()

        # Проверка корректности
        try:
            date_obj = datetime.strptime(date_str, "%Y-%m-%d")
        except ValueError:
            messagebox.showerror("Ошибка", "Неверный формат даты. Используйте YYYY-MM-DD.")
            return

        try:
            temp = float(temp_str)
        except ValueError:
            messagebox.showerror("Ошибка", "Температура должна быть числом.")
            return

        if not desc:
            messagebox.showerror("Ошибка", "Описание погоды не должно быть пустым.")
            return

        record = {
            "date": date_str,
            "temperature": temp,
            "description": desc,
            "precipitation": precip
        }

        self.data.append(record)
        self.insert_into_tree(record)
        self.clear_entries()

    def insert_into_tree(self, record):
        precip_text = "Да" if record["precipitation"] else "Нет"
        self.tree.insert("", "end", values=(
            record["date"],
            record["temperature"],
            record["description"],
            precip_text
        ))

    def clear_entries(self):
        self.date_entry.delete(0, tk.END)
        self.temp_entry.delete(0, tk.END)
        self.desc_entry.delete(0, tk.END)
        self.precip_var.set(False)

    def save_data(self):
        filename = filedialog.asksaveasfilename(defaultextension=".json",
                                                filetypes=[("JSON files", "*.json")])
        if filename:
            try:
                with open(filename, "w", encoding='utf-8') as f:
                    json.dump(self.data, f, ensure_ascii=False, indent=4)
                messagebox.showinfo("Успех", "Данные успешно сохранены.")
            except Exception as e:
                messagebox.showerror("Ошибка", f"Не удалось сохранить файл: {e}")

    def load_data(self):
        filename = filedialog.askopenfilename(filetypes=[("JSON files", "*.json")])
        if filename:
            try:
                with open(filename, "r", encoding='utf-8') as f:
                    self.data = json.load(f)
                self.refresh_tree()
                messagebox.showinfo("Успех", "Данные загружены.")
            except Exception as e:
                messagebox.showerror("Ошибка", f"Не удалось загрузить файл: {e}")

    def refresh_tree(self, data=None):
        for item in self.tree.get_children():
            self.tree.delete(item)
        if data is None:
            data = self.data
        for record in data:
            self.insert_into_tree(record)

    def show_all(self):
        self.refresh_tree()

    def filter_by_date(self):
        date_str = self.filter_date_entry.get().strip()
        try:
            datetime.strptime(date_str, "%Y-%m-%d")
        except ValueError:
            messagebox.showerror("Ошибка", "Неверный формат даты для фильтра.")
            return
        filtered = [rec for rec in self.data if rec["date"] == date_str]
        self.refresh_tree(filtered)

    def filter_by_temperature(self):
        temp_str = self.filter_temp_entry.get().strip()
        try:
            temp_threshold = float(temp_str)
        except ValueError:
            messagebox.showerror("Ошибка", "Пожалуйста, введите число для фильтрации по температуре.")
            return
        filtered = [rec for rec in self.data if rec["temperature"] > temp_threshold]
        self.refresh_tree(filtered)

if __name__ == "__main__":
    root = tk.Tk()
    app = WeatherDiary(root)
    root.mainloop()
